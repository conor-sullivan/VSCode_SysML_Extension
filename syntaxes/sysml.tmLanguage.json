{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "SysML",
    "scopeName": "source.sysml",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#constants"
        },
        {
            "include": "#def-declarations"
        },
        {
            "include": "#usage-declarations"
        },
        {
            "include": "#type-annotations"
        },
        {
            "include": "#modifiers"
        },
        {
            "include": "#control-keywords"
        },
        {
            "include": "#definition-keywords"
        },
        {
            "include": "#relationship-keywords"
        },
        {
            "include": "#other-keywords"
        },
        {
            "include": "#operators"
        },
        {
            "include": "#builtin-types"
        },
        {
            "include": "#punctuation"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.sysml",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.sysml",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.sysml",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.sysml",
                            "match": "\\\\."
                        }
                    ]
                },
                {
                    "name": "string.quoted.single.sysml",
                    "begin": "'",
                    "end": "'",
                    "patterns": [
                        {
                            "name": "constant.character.escape.sysml",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.float.sysml",
                    "match": "\\b\\d+\\.\\d+([eE][+-]?\\d+)?\\b"
                },
                {
                    "name": "constant.numeric.integer.sysml",
                    "match": "\\b\\d+\\b"
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "name": "constant.language.sysml",
                    "match": "\\b(true|false|null)\\b"
                }
            ]
        },
        "def-declarations": {
            "comment": "keyword def Name — name is a type definition (teal/green in Dark+)",
            "patterns": [
                {
                    "comment": "Compound: use case def Name",
                    "match": "\\b(use\\s+case)\\s+(def)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
                    "captures": {
                        "1": {
                            "name": "keyword.other.definition.sysml"
                        },
                        "2": {
                            "name": "storage.type.def.sysml"
                        },
                        "3": {
                            "name": "entity.name.type.sysml"
                        }
                    }
                },
                {
                    "match": "\\b(package|part|port|item|attribute|action|calc|state|constraint|requirement|concern|case|analysis|verification|view|viewpoint|rendering|metadata|enum|allocation|connection|interface|occurrence|individual|flow|binding|succession)\\s+(def)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
                    "captures": {
                        "1": {
                            "name": "keyword.other.definition.sysml"
                        },
                        "2": {
                            "name": "storage.type.def.sysml"
                        },
                        "3": {
                            "name": "entity.name.type.sysml"
                        }
                    }
                }
            ]
        },
        "usage-declarations": {
            "comment": "keyword name (without def) — names get role-appropriate scopes",
            "patterns": [
                {
                    "comment": "include use case name — include relationship",
                    "match": "\\b(include)\\s+(use)\\s+(case)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
                    "captures": {
                        "1": {
                            "name": "keyword.control.sysml"
                        },
                        "2": {
                            "name": "keyword.other.definition.sysml"
                        },
                        "3": {
                            "name": "keyword.other.definition.sysml"
                        },
                        "4": {
                            "name": "variable.other.member.sysml"
                        }
                    }
                },
                {
                    "comment": "use case name (without def)",
                    "match": "\\b(use)\\s+(case)\\s+(?!def\\b)([a-zA-Z_][a-zA-Z0-9_]*)",
                    "captures": {
                        "1": {
                            "name": "keyword.other.definition.sysml"
                        },
                        "2": {
                            "name": "keyword.other.definition.sysml"
                        },
                        "3": {
                            "name": "variable.other.member.sysml"
                        }
                    }
                },
                {
                    "comment": "perform action name",
                    "match": "\\b(perform)\\s+(action)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
                    "captures": {
                        "1": {
                            "name": "keyword.control.sysml"
                        },
                        "2": {
                            "name": "keyword.other.definition.sysml"
                        },
                        "3": {
                            "name": "entity.name.function.sysml"
                        }
                    }
                },
                {
                    "comment": "exhibit state name",
                    "match": "\\b(exhibit)\\s+(state)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
                    "captures": {
                        "1": {
                            "name": "keyword.control.sysml"
                        },
                        "2": {
                            "name": "keyword.other.definition.sysml"
                        },
                        "3": {
                            "name": "variable.other.member.sysml"
                        }
                    }
                },
                {
                    "comment": "actor/subject name — participant (light blue in Dark+)",
                    "match": "\\b(actor|subject)\\s+([a-zA-Z_][a-zA-Z0-9_]*)(?!\\s+def\\b)",
                    "captures": {
                        "1": {
                            "name": "keyword.other.definition.sysml"
                        },
                        "2": {
                            "name": "variable.other.member.sysml"
                        }
                    }
                },
                {
                    "comment": "package/namespace Name — namespace (teal in Dark+)",
                    "match": "\\b(package|namespace|library)\\s+([a-zA-Z_][a-zA-Z0-9_]*)(?!\\s+def\\b)",
                    "captures": {
                        "1": {
                            "name": "keyword.other.definition.sysml"
                        },
                        "2": {
                            "name": "entity.name.namespace.sysml"
                        }
                    }
                },
                {
                    "comment": "action/calc name — function-like (yellow in Dark+)",
                    "match": "\\b(action|calc|analysis|verification)\\s+([a-zA-Z_][a-zA-Z0-9_]*)(?!\\s+def\\b)",
                    "captures": {
                        "1": {
                            "name": "keyword.other.definition.sysml"
                        },
                        "2": {
                            "name": "entity.name.function.sysml"
                        }
                    }
                },
                {
                    "comment": "part/port/item name — member (light blue in Dark+)",
                    "match": "\\b(part|port|item|state|constraint|requirement|concern|case|view|viewpoint|rendering|allocation|connection|interface|occurrence|individual|flow|binding|succession|metadata|enum)\\s+([a-zA-Z_][a-zA-Z0-9_]*)(?!\\s+def\\b)",
                    "captures": {
                        "1": {
                            "name": "keyword.other.definition.sysml"
                        },
                        "2": {
                            "name": "variable.other.member.sysml"
                        }
                    }
                },
                {
                    "comment": "attribute name — property (light blue in Dark+)",
                    "match": "\\b(attribute)\\s+([a-zA-Z_][a-zA-Z0-9_]*)(?!\\s+def\\b)",
                    "captures": {
                        "1": {
                            "name": "keyword.other.definition.sysml"
                        },
                        "2": {
                            "name": "variable.other.property.sysml"
                        }
                    }
                }
            ]
        },
        "type-annotations": {
            "comment": "Type references after colon or specialization operators",
            "patterns": [
                {
                    "comment": "':> TypeName' or ':>> TypeName' — specialization/redefinition",
                    "match": "(:>>|:>)\\s*([a-zA-Z_][a-zA-Z0-9_]*)",
                    "captures": {
                        "1": {
                            "name": "keyword.operator.sysml"
                        },
                        "2": {
                            "name": "entity.name.type.sysml"
                        }
                    }
                },
                {
                    "comment": "': TypeName' — PascalCase identifiers after colon are type references",
                    "match": "(:)\\s*([A-Z][a-zA-Z0-9_]*)",
                    "captures": {
                        "1": {
                            "name": "punctuation.separator.type.sysml"
                        },
                        "2": {
                            "name": "entity.name.type.sysml"
                        }
                    }
                }
            ]
        },
        "modifiers": {
            "patterns": [
                {
                    "name": "storage.modifier.sysml",
                    "match": "\\b(abstract|derived|readonly|nonunique|ordered|private|protected|public|ref|in|out|inout)\\b"
                }
            ]
        },
        "control-keywords": {
            "patterns": [
                {
                    "name": "keyword.control.sysml",
                    "match": "\\b(if|else|then|while|for|do|return|accept|send|after|when|entry|exit|transition|decide|fork|join|merge|first|include|perform|exhibit|assign|assert|assume|satisfy|require|verify|from|to|by)\\b"
                }
            ]
        },
        "definition-keywords": {
            "comment": "Standalone definition keywords (when not already matched by declarations above)",
            "patterns": [
                {
                    "name": "keyword.other.definition.sysml",
                    "match": "\\b(package|part|port|item|attribute|action|calc|state|constraint|requirement|concern|case|analysis|verification|view|viewpoint|rendering|metadata|comment|doc|alias|namespace|library|allocation|connection|interface|binding|succession|flow|use|import|expose|dependency|stakeholder|enum|occurrence|individual|snapshot|timeslice|multiplicity|feature|type|def|actor|event|connect|allocate|bind)\\b"
                }
            ]
        },
        "relationship-keywords": {
            "patterns": [
                {
                    "name": "keyword.operator.relationship.sysml",
                    "match": "\\b(specializes|subsets|redefines|references|defined|hastype|istype)\\b"
                }
            ]
        },
        "other-keywords": {
            "patterns": [
                {
                    "name": "keyword.other.sysml",
                    "match": "\\b(about|of|all|as|default|end|filter|frame|language|locale|message|meta|objective|parallel|render|rep|subject|variant|variation|new)\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.logical.sysml",
                    "match": "\\b(and|or|not|xor|implies)\\b"
                },
                {
                    "name": "keyword.operator.sysml",
                    "match": ":>>|:>|::|\\.\\.\\.|\\.\\.|\\.\\*|=>|==|!=|>=|<=|>|<|\\+|-|\\*|/|%|\\^"
                }
            ]
        },
        "builtin-types": {
            "patterns": [
                {
                    "name": "support.type.builtin.sysml",
                    "match": "\\b(Boolean|Integer|Real|String|Natural|Positive|ScalarValues|NumericalValue|DataValues)\\b"
                }
            ]
        },
        "punctuation": {
            "patterns": [
                {
                    "name": "punctuation.definition.block.sysml",
                    "match": "[{}]"
                },
                {
                    "name": "punctuation.separator.sysml",
                    "match": ";"
                }
            ]
        }
    }
}
